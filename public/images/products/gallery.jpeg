const gallery = document.getElementById('gallery');
files.forEach(file => {
  const div = document.createElement('div');
  div.className = 'photo';
  div.innerHTML = `<img src="${file}" alt="${file}" loading="lazy"><div class="filename">${file}</div>`;
  gallery.appendChild(div);
});
